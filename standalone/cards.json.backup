{
  "tabs": [
    {
      "id": "dashboard",
      "title": "Dashboard",
      "type": "dashboard"
    },
    {
      "id": "model",
      "title": "Model",
      "type": "cards",
      "cardType": "model",
      "cards": [
        {
          "id": "smt",
          "title": "Shallow Moments (Topo)",
          "class": "zoomy_core.model.models.shallow_moments_topo.ShallowMomentsTopo",
          "init": {"level": 2, "dimension": 2},
          "template": "from zoomy_core.model.models.shallow_moments_topo import ShallowMomentsTopo\n\nclass UserModel(ShallowMomentsTopo):\n    pass",
          "description": "Galerkin-projected shallow water equations.<br>$$\\partial_t \\mathbf{Q} + \\nabla \\cdot \\mathbf{F}(\\mathbf{Q}) + \\mathbf{B}(\\mathbf{Q}) \\nabla \\mathbf{Q} = \\mathbf{S}(\\mathbf{Q})$$"
        },
        {
          "id": "swt",
          "title": "Shallow Water (Topo)",
          "class": "zoomy_core.model.models.shallow_water_topo.ShallowWaterEquationsWithTopo",
          "init": {"dimension": 2},
          "template": "from zoomy_core.model.models.shallow_water_topo import ShallowWaterEquationsWithTopo\n\nclass UserModel(ShallowWaterEquationsWithTopo):\n    pass",
          "description": "Classical Saint-Venant equations.<br>$$\\partial_t \\mathbf{Q} + \\nabla \\cdot \\mathbf{F}(\\mathbf{Q}) = \\mathbf{S}(\\mathbf{Q})$$"
        }
      ]
    },
    {
      "id": "mesh",
      "title": "Mesh",
      "type": "cards",
      "cardType": "mesh",
      "cards": [
        {
          "id": "mesh-channel",
          "title": "Channel (Quad 2D)",
          "description": "Pre-built 2D quad channel mesh.<br><img src='previews/mesh_channel_quad_2d_mesh.svg' alt='channel mesh'>",
          "mesh_sizes": ["coarse"]
        },
        {
          "id": "mesh-1d",
          "title": "Create 1D Mesh",
          "init": {"x_min": 0.0, "x_max": 1.0, "n_cells": 100},
          "description": "Uniform 1D mesh from bounding box and resolution.",
          "template": "import numpy as np\n\nx_min, x_max, n_cells = {x_min}, {x_max}, {n_cells}\ndx = (x_max - x_min) / n_cells\nprint(f'1D mesh: {n_cells} cells, dx={dx:.4f}')"
        },
        {
          "id": "mesh-2d",
          "title": "Create 2D Mesh",
          "init": {"x_min": 0.0, "x_max": 1.0, "y_min": 0.0, "y_max": 1.0, "nx": 50, "ny": 50},
          "description": "Uniform 2D mesh from bounding box and resolution.",
          "template": "import numpy as np\n\nx_min, x_max, nx = {x_min}, {x_max}, {nx}\ny_min, y_max, ny = {y_min}, {y_max}, {ny}\ndx, dy = (x_max-x_min)/nx, (y_max-y_min)/ny\nprint(f'2D mesh: {nx}x{ny}, dx={dx:.4f}, dy={dy:.4f}')"
        }
      ]
    },
    {
      "id": "solver",
      "title": "Solver",
      "type": "cards",
      "cardType": "solver",
      "cards": [
        {
          "id": "solver-numpy",
          "title": "NumPy Solver",
          "description": "HyperbolicSolver with NumPy backend. Available via Pyodide (browser) or Docker.",
          "requires_tag": "numpy",
          "template": "# NumPy solver\ndt = 0.001\nt_end = 1.0"
        },
        {
          "id": "solver-jax",
          "title": "JAX Solver",
          "description": "GPU-accelerated JAX solver via Docker backend.",
          "requires_tag": "jax"
        },
        {
          "id": "solver-amrex",
          "title": "AMReX Solver",
          "description": "Block-structured AMR solver via Docker backend.",
          "requires_tag": "amrex"
        }
      ]
    },
    {
      "id": "visualization",
      "title": "Visualization",
      "type": "cards",
      "cardType": "vis",
      "subtabs": [
        {"id": "matplotlib", "title": "Matplotlib"},
        {"id": "pyvista", "title": "PyVista"}
      ],
      "cards": [
        {
          "id": "vis-empty-mpl",
          "subtab": "matplotlib",
          "title": "Empty Figure",
          "template": "import matplotlib.pyplot as plt\n\nfig, ax = plt.subplots(1, 1, figsize=(6, 4))\nax.set_title('Empty View')\nax.set_xlabel('x')\nax.set_ylabel('y')",
          "description": "Empty matplotlib subplots."
        },
        {
          "id": "vis-sine",
          "subtab": "pyvista",
          "title": "Sine Wave",
          "snippet": "snippets/sine_wave.py",
          "preview": "previews/sine_wave.svg",
          "description": "Interactive sine wave plot.",
          "has_timeline": false
        },
        {
          "id": "vis-topo",
          "subtab": "pyvista",
          "title": "Topography",
          "snippet": "snippets/topo.py",
          "preview": "previews/topo.svg",
          "description": "3D topography mesh.",
          "has_timeline": true
        },
        {
          "id": "vis-cone",
          "subtab": "pyvista",
          "title": "Cone 3D",
          "snippet": "snippets/cone_3d.py",
          "preview": "previews/cone_3d.svg",
          "description": "3D cone vector field."
        }
      ]
    }
  ]
