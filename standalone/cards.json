      "id": "mesh",
      "title": "Mesh",
      "type": "cards",
      "cardType": "mesh",
      "layout": "grid",
      "columns": 2,
      "cards": [
        {
          "id": "mesh-create-1d",
          "title": "Create 1D",
          "source": "builtin",
          "init": {"x_min": 0.0, "x_max": 10.0, "n_cells": 100},
          "description": "Uniform 1D mesh",
          "template": "from zoomy_core.mesh import BaseMesh\nmesh = BaseMesh.create_1d(domain=({x_min}, {x_max}), n_inner_cells={n_cells})\n"
        },
        {
          "id": "mesh-create-2d",
          "title": "Create 2D",
          "source": "builtin",
          "init": {"x_min": 0.0, "x_max": 1.0, "y_min": 0.0, "y_max": 1.0, "nx": 50, "ny": 50},
          "description": "Uniform 2D quad mesh",
          "template": "from zoomy_core.mesh import BaseMesh\nmesh = BaseMesh.create_2d(({x_min}, {x_max}, {y_min}, {y_max}), nx={nx}, ny={ny})\n"
        },
        {
          "id": "mesh-create-3d",
          "title": "Create 3D",
          "source": "builtin",
          "init": {"x_min": 0.0, "x_max": 1.0, "y_min": 0.0, "y_max": 1.0, "z_min": 0.0, "z_max": 1.0, "nx": 10, "ny": 10, "nz": 10},
          "description": "Uniform 3D hex mesh",
          "template": "from zoomy_core.mesh import BaseMesh\nmesh = BaseMesh.create_3d(({x_min}, {x_max}, {y_min}, {y_max}, {z_min}, {z_max}), nx={nx}, ny={ny}, nz={nz})\n"
        }
      ]
    },
